# URL вашого сайту для продакшн-збірки.
SITE="http://localhost:4321"

# URL для підключення до вашого Redis-сервера.
# Для локального запуску за замовчуванням це значення підходить.
REDIS_URL="redis://localhost:6379"

# Секретний ключ для доступу до вашого зовнішнього API (приклад).
# YOUR_API_KEY=your_secret_key_here